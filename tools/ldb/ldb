#!/usr/bin/env python3
"""ldb — thin command-line client for the ldbd daemon (M5 part 4).

Spawns `ldbd --stdio` as a child process per invocation, sends one
JSON-RPC request, and prints the response.

Usage:
    ldb [--ldbd PATH | --ssh [user@]host[:port]] [--format json|cbor]
        [--verbose] [--raw]
        <subcommand> [key=value ...] [--view k=v ...]

Subcommands are discovered dynamically from `describe.endpoints` on
startup. Per-method `--help` prints the JSON Schema for the call's
parameters in human-readable form.

Design notes:

  • One-shot per invocation OR persistent --repl. By default the daemon
    is spawned, called once, and torn down. With --repl the daemon
    survives across many commands inside one interactive session —
    target_id and other daemon-side state persist.
  • Schema-driven param parsing. Type coercion (string/integer/number/
    boolean/array) is derived from the endpoint's `params_schema`, which
    means new endpoints work without CLI updates.
  • View descriptors. `--view k=v` (repeatable) collapses into
    `params.view = {k: v, ...}` with type coercion (`limit`/`offset` ->
    int, `summary` -> bool, `fields` -> array).
  • Stdout discipline. The daemon's stdout is the JSON-RPC channel — we
    pipe it through, capture stderr separately, and print our own output
    on the CLI's stdout.
  • Transport. By default the daemon runs locally as a child process.
    With --ssh user@host the same `ldbd --stdio` is spawned on the remote
    via `ssh user@host -- ldbd --stdio`; the agent's wire bytes flow
    through ssh's stdin/stdout exec channel unchanged. No daemon-side
    code changes — ssh is just a transport. See post-V1 plan #11.

The CLI depends only on Python's stdlib. Optional: prompt_toolkit for
nicer REPL completion; readline is the fallback. CBOR support is
hand-rolled for the wire-format subset ldbd emits.
"""
from __future__ import annotations

import argparse
import errno
import io
import json
import os
import shutil
import socket
import struct
import subprocess
import sys
import time
from typing import Any


# ----------------------------------------------------------------------
# CBOR codec — minimal subset matching nlohmann::json::to_cbor output.
# (Same shapes as the daemon emits: maps, arrays, strings, ints, bools,
# null. No tags, no floats beyond f32/f64, no big integers.)
# ----------------------------------------------------------------------

def _cbor_uint(major: int, n: int, out: bytearray) -> None:
    if n < 24:
        out.append((major << 5) | n)
    elif n < 1 << 8:
        out.append((major << 5) | 24)
        out.append(n)
    elif n < 1 << 16:
        out.append((major << 5) | 25)
        out += struct.pack(">H", n)
    elif n < 1 << 32:
        out.append((major << 5) | 26)
        out += struct.pack(">I", n)
    else:
        out.append((major << 5) | 27)
        out += struct.pack(">Q", n)


def cbor_encode(v: Any) -> bytes:
    out = bytearray()
    _cbor_enc(v, out)
    return bytes(out)


def _cbor_enc(v: Any, out: bytearray) -> None:
    if v is None:
        out.append(0xf6)
    elif v is True:
        out.append(0xf5)
    elif v is False:
        out.append(0xf4)
    elif isinstance(v, int):
        if v >= 0:
            _cbor_uint(0, v, out)
        else:
            _cbor_uint(1, -1 - v, out)
    elif isinstance(v, float):
        out.append(0xfb)
        out += struct.pack(">d", v)
    elif isinstance(v, str):
        b = v.encode("utf-8")
        _cbor_uint(3, len(b), out)
        out += b
    elif isinstance(v, (bytes, bytearray)):
        _cbor_uint(2, len(v), out)
        out += v
    elif isinstance(v, list):
        _cbor_uint(4, len(v), out)
        for x in v:
            _cbor_enc(x, out)
    elif isinstance(v, dict):
        _cbor_uint(5, len(v), out)
        for k, x in v.items():
            _cbor_enc(k, out)
            _cbor_enc(x, out)
    else:
        raise TypeError(f"unsupported type for cbor encode: {type(v)}")


def _cbor_read_uint(buf: bytes, i: int, info: int):
    if info < 24:
        return info, i
    if info == 24:
        return buf[i], i + 1
    if info == 25:
        return struct.unpack_from(">H", buf, i)[0], i + 2
    if info == 26:
        return struct.unpack_from(">I", buf, i)[0], i + 4
    if info == 27:
        return struct.unpack_from(">Q", buf, i)[0], i + 8
    raise ValueError(f"unsupported additional info {info}")


def _cbor_dec(buf: bytes, i: int):
    b = buf[i]
    i += 1
    major = b >> 5
    info = b & 0x1f
    if major == 0:
        n, i = _cbor_read_uint(buf, i, info)
        return n, i
    if major == 1:
        n, i = _cbor_read_uint(buf, i, info)
        return -1 - n, i
    if major == 2:
        n, i = _cbor_read_uint(buf, i, info)
        return bytes(buf[i:i + n]), i + n
    if major == 3:
        n, i = _cbor_read_uint(buf, i, info)
        return buf[i:i + n].decode("utf-8"), i + n
    if major == 4:
        n, i = _cbor_read_uint(buf, i, info)
        out = []
        for _ in range(n):
            v, i = _cbor_dec(buf, i)
            out.append(v)
        return out, i
    if major == 5:
        n, i = _cbor_read_uint(buf, i, info)
        out = {}
        for _ in range(n):
            k, i = _cbor_dec(buf, i)
            v, i = _cbor_dec(buf, i)
            out[k] = v
        return out, i
    if major == 7:
        if info == 20:
            return False, i
        if info == 21:
            return True, i
        if info == 22:
            return None, i
        if info == 23:
            return None, i  # undefined
        if info == 26:
            v, = struct.unpack_from(">f", buf, i)
            return v, i + 4
        if info == 27:
            v, = struct.unpack_from(">d", buf, i)
            return v, i + 8
        raise ValueError(f"unsupported simple/float info {info}")
    raise ValueError(f"unsupported major type {major}")


def cbor_decode(buf: bytes) -> Any:
    v, i = _cbor_dec(buf, 0)
    if i != len(buf):
        raise ValueError(f"trailing bytes: consumed {i} of {len(buf)}")
    return v


# ----------------------------------------------------------------------
# Wire transport — JSON line-delimited or CBOR length-prefixed.
# ----------------------------------------------------------------------

class JsonTransport:
    def __init__(self, proc):
        self.proc = proc

    def send(self, msg):
        line = json.dumps(msg)
        self.proc.stdin.write(line.encode("utf-8") + b"\n")
        self.proc.stdin.flush()

    def recv(self):
        line = self.proc.stdout.readline()
        if not line:
            return None
        return json.loads(line)


class CborTransport:
    def __init__(self, proc):
        self.proc = proc

    def send(self, msg):
        body = cbor_encode(msg)
        self.proc.stdin.write(struct.pack(">I", len(body)))
        self.proc.stdin.write(body)
        self.proc.stdin.flush()

    def recv(self):
        prefix = self.proc.stdout.read(4)
        if len(prefix) == 0:
            return None
        if len(prefix) != 4:
            raise IOError(f"short prefix read: got {len(prefix)} bytes")
        n, = struct.unpack(">I", prefix)
        body = self.proc.stdout.read(n)
        if len(body) != n:
            raise IOError(f"short body: wanted {n}, got {len(body)}")
        return cbor_decode(body)


# ----------------------------------------------------------------------
# Daemon discovery + lifecycle.
# ----------------------------------------------------------------------

class DaemonSpec:
    """How to spawn the daemon. Either local (a path to ldbd), ssh, or
    a unix-socket connection to an already-running `ldbd --listen ...`.

    The rest of the CLI treats all three the same — `spawn_daemon(spec, ...)`
    returns an object whose stdin/stdout speak the JSON-RPC channel.
    For local/ssh that object is a `subprocess.Popen`; for the unix
    socket path it's a `_SocketProc` shim that exposes the same
    `stdin` / `stdout` / `stderr` / `wait()` / `kill()` interface.
    """
    __slots__ = ("local_ldbd", "ssh_target", "ssh_key", "ssh_options",
                 "remote_ldbd", "socket_path")

    def __init__(self):
        self.local_ldbd: str | None = None
        self.ssh_target: str | None = None
        self.ssh_key: str | None = None
        self.ssh_options: str | None = None  # extra raw "-o ..." string
        self.remote_ldbd: str = "ldbd"
        self.socket_path: str | None = None

    @property
    def is_ssh(self) -> bool:
        return self.ssh_target is not None

    @property
    def is_socket(self) -> bool:
        return self.socket_path is not None


def default_socket_path() -> str:
    """Return the default unix-socket path per §2 phase-1 policy.

    Resolution order (matches `ldbd --help`):
      $XDG_RUNTIME_DIR/ldbd.sock   if XDG_RUNTIME_DIR is set
      $TMPDIR/ldbd-$UID.sock       if TMPDIR is set
      /tmp/ldbd-$UID.sock          fallback
    """
    xdg = os.environ.get("XDG_RUNTIME_DIR")
    if xdg:
        return os.path.join(xdg, "ldbd.sock")
    tmpdir = os.environ.get("TMPDIR") or "/tmp"
    uid = os.geteuid() if hasattr(os, "geteuid") else 0
    return os.path.join(tmpdir, f"ldbd-{uid}.sock")


def _looks_like_ldbd(path: str) -> bool:
    """Run `<path> --version` and check the output contains `ldbd`.

    Post-review I5: `LDB_LDBD_SPAWN` was checked with `os.access(path,
    X_OK)` only. If pointed at a generic executable like `/usr/bin/yes`
    the spawn forked a process that never bound; the client retried
    for ~3s and then surfaced "auto-spawned ldbd never began
    accepting" with no hint that the operator's env var was wrong.

    A lightweight `--version` probe with a tight timeout costs a few
    ms at startup and converts the failure mode from "3s of mystery
    retries" to "ldb: LDB_LDBD_SPAWN points at /usr/bin/yes which
    does not look like ldbd".

    Returns True if the probe succeeded AND its stdout/stderr
    contains the literal string "ldbd". A path that can't be exec'd,
    times out, or produces unrelated output returns False; the caller
    then falls through to the next resolution step.
    """
    try:
        proc = subprocess.run(
            [path, "--version"],
            capture_output=True,
            text=True,
            timeout=2.0,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    if proc.returncode != 0:
        return False
    # `ldbd --version` prints something like "ldbd 1.6.1"; we accept
    # the literal "ldbd" anywhere in stdout or stderr to avoid pinning
    # the format. Other binaries called via this path (e.g. /usr/bin/yes)
    # won't contain the string.
    return "ldbd" in (proc.stdout + proc.stderr)


def _resolve_autospawn_ldbd() -> str | None:
    """Find an `ldbd` binary suitable for auto-spawn.

    Resolution order:
      1. `$LDB_LDBD_SPAWN`           — explicit operator override (also
                                       used by the smoke test to pin
                                       the build's ldbd binary). We
                                       validate it's actually an ldbd
                                       (post-review I5) — `--version`
                                       must succeed AND the output
                                       must contain "ldbd". A mistyped
                                       path that's executable but
                                       isn't ldbd would otherwise spawn
                                       a child that never binds and
                                       the client would burn ~3s of
                                       retries before failing with
                                       "auto-spawned ldbd never began
                                       accepting" — no signal that
                                       the env var was wrong.
      2. `shutil.which("ldbd")`      — `ldbd` on `$PATH`.
      3. `_find_ldbd_sibling()`      — `<repo>/build/bin/ldbd` if the
                                       `ldb` CLI is being run from a
                                       checkout.
    Returns the resolved absolute path, or None when nothing was found
    (caller surfaces a "could not auto-spawn" diagnostic). We don't
    auto-spawn from an arbitrary local path the user typed via `--ldbd`
    because `--ldbd` is mutually exclusive with `--socket` anyway.
    """
    env = os.environ.get("LDB_LDBD_SPAWN")
    if env:
        if not os.access(env, os.X_OK):
            sys.stderr.write(
                f"ldb: LDB_LDBD_SPAWN={env!r} is not executable; "
                f"ignoring and falling through to PATH lookup\n")
        elif not _looks_like_ldbd(env):
            sys.stderr.write(
                f"ldb: LDB_LDBD_SPAWN={env!r} does not look like ldbd "
                f"(--version did not mention ldbd); ignoring and "
                f"falling through to PATH lookup\n")
        else:
            return env
    onpath = shutil.which("ldbd")
    if onpath:
        return onpath
    sibling = _find_ldbd_sibling()
    if sibling:
        return sibling
    return None


def _autospawn_daemon(sock_path: str, verbose: bool) -> bool:
    """Fork+exec `ldbd --listen unix:<sock_path>` detached from us.

    "Detached" = the daemon outlives the client process. We
    fork-exec a child that calls `setsid()`. stdin/stdout are
    redirected to /dev/null. stderr is ALSO redirected to /dev/null
    by default — this is what the post-review N1 cleanup pins. A
    prior version inherited the client's stderr but that broke any
    caller that wrapped `ldb` with subprocess.run(capture_output=
    True) because the daemon kept the captured-stderr pipe alive
    indefinitely. Operators who want diagnostics export
    LDB_LDBD_LOG_FILE; stderr then goes to that path instead of
    /dev/null. Returns True if the spawn was initiated (caller still
    waits for the socket to start accepting), False if no ldbd
    binary was found.
    """
    ldbd = _resolve_autospawn_ldbd()
    if not ldbd:
        return False

    if verbose:
        sys.stderr.write(
            f"ldb: auto-spawning {ldbd} --listen unix:{sock_path}\n")

    # Use start_new_session=True for setsid() — the daemon detaches
    # from our process group / controlling terminal so it survives
    # the CLI process's exit. stdin/stdout/stderr are ALL redirected
    # to /dev/null. The original implementation inherited the
    # client's stderr so operators could see diagnostics, but that
    # broke any caller that wrapped `ldb` with subprocess.run
    # capture_output=True — the daemon kept the captured-stderr pipe
    # alive, and the wrapper hung forever on a read that never saw
    # EOF. Diagnostics are still available via $LDB_LDBD_LOG_FILE:
    # if set, stderr is redirected there instead of /dev/null so an
    # operator can opt in by exporting the variable in their shell.
    log_path = os.environ.get("LDB_LDBD_LOG_FILE")
    devnull = open(os.devnull, "rb")
    devnull_w = open(os.devnull, "wb")
    log_fh = None
    if log_path:
        try:
            log_fh = open(log_path, "ab")
        except OSError as e:
            sys.stderr.write(
                f"ldb: cannot open LDB_LDBD_LOG_FILE {log_path!r}: {e}; "
                f"daemon stderr will be discarded\n")
            log_fh = None
    try:
        subprocess.Popen(
            [ldbd, "--listen", f"unix:{sock_path}", "--log-level", "error"],
            stdin=devnull,
            stdout=devnull_w,
            stderr=log_fh if log_fh is not None else devnull_w,
            start_new_session=True,
            close_fds=True,
        )
    finally:
        devnull.close()
        devnull_w.close()
        if log_fh is not None:
            log_fh.close()
    return True


class _SocketProc:
    """Popen-shaped adapter wrapping a connected unix socket.

    `stdin` / `stdout` expose the socket's send/recv halves through
    Python's `socket.makefile()` so the existing
    `JsonTransport`/`CborTransport` plumbing works unchanged. `stderr`
    is a static empty BytesIO — when the daemon talks via a socket,
    its log lines go to ITS stderr (we never see them), so reading
    from this shim's stderr in error paths simply returns b"". Code
    paths that report "daemon stderr was: ..." just print an empty
    string in socket mode — acceptable for phase 1.

    Phase-2 auto-spawn: if the initial connect() fails with
    ECONNREFUSED / ENOENT, we fork+exec `ldbd --listen unix:PATH`
    as a detached subprocess and retry the connect with a short
    backoff. The auto-spawned daemon outlives the client process so
    the next invocation reuses it. Disabled by passing
    `autospawn=False` (used by tests that want a hard "no daemon"
    failure).
    """

    def __init__(self, sock_path: str, autospawn: bool = True,
                 verbose: bool = False):
        self._sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        try:
            self._sock.connect(sock_path)
        except OSError as e:
            self._sock.close()
            # Auto-spawn is gated to "no daemon listening here" errors:
            # ECONNREFUSED (socket inode exists but nobody accept()s)
            # and ENOENT (no inode at all). Any other error — EACCES,
            # ELOOP, ENOTDIR — is a configuration problem the user
            # has to fix; retrying after spawn wouldn't change it.
            transient = e.errno in (
                errno.ECONNREFUSED, errno.ENOENT, errno.ENXIO)
            if not autospawn or not transient:
                raise IOError(
                    f"could not connect to ldbd socket {sock_path!r}: {e}"
                ) from None
            if not _autospawn_daemon(sock_path, verbose):
                raise IOError(
                    f"could not auto-spawn ldbd for {sock_path!r}: "
                    f"daemon binary not found. Check LDB_LDBD_SPAWN, "
                    f"$PATH, and the sibling-of-ldb heuristic."
                ) from None
            # Retry the connect with bounded backoff. The auto-spawned
            # daemon needs a moment to bind + listen; 200ms * 15 retries
            # (~3s) is generous on macOS, very loose on Linux. (N2:
            # was previously commented as "200ms * 10 (~2s)" which
            # didn't match the loop bound — pinning the comment to
            # the actual constants now.)
            self._sock = None
            connected = False
            last_err: OSError | None = None
            for _ in range(15):
                # N5: re-create the socket inside the retry loop. A
                # POSIX socket whose connect() failed is left in an
                # unspecified state — reusing it for another connect()
                # works on macOS and Linux today but is pedantically
                # undefined. Allocating fresh is one extra syscall per
                # iteration and removes the corner case entirely.
                s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
                try:
                    s.connect(sock_path)
                    self._sock = s
                    connected = True
                    break
                except OSError as retry_err:
                    last_err = retry_err
                    s.close()
                    time.sleep(0.2)
            if not connected:
                raise IOError(
                    f"auto-spawned ldbd never began accepting on "
                    f"{sock_path!r}; last connect error: {last_err}. "
                    f"Check stderr / LDB_LDBD_LOG_FILE for daemon-side "
                    f"errors."
                ) from None
        # 5-minute recv timeout matches the daemon's SO_RCVTIMEO. A
        # hung daemon (deadlocked dispatcher, runaway target.open)
        # must NOT pin `fetch_catalog` or `do_rpc` forever — without
        # this the CLI would block on the makefile.read() with no
        # signal-safe escape. socket.timeout is translated upstream
        # into a clean error message; see do_rpc/fetch_catalog.
        self._sock.settimeout(300)
        # makefile() on a socket bumps a ref so the file object's close
        # doesn't tear the underlying socket out from under the other
        # half. We separately close `self._sock` in `wait()`/`kill()`.
        self.stdin = self._sock.makefile("wb", buffering=0)
        self.stdout = self._sock.makefile("rb", buffering=0)
        self.stderr = io.BytesIO()
        self.returncode: int | None = None

    def wait(self, timeout: float | None = None):
        # No subprocess to reap — but signal cleanup intent by closing
        # the socket so the daemon's accept() loop can move on to the
        # next caller. shutdown() first to flush the kernel send buffer
        # and let the daemon see EOF promptly.
        if self.returncode is None:
            try:
                self._sock.shutdown(socket.SHUT_RDWR)
            except OSError:
                pass
            try:
                self._sock.close()
            except OSError:
                pass
            self.returncode = 0
        return 0

    def kill(self):
        if self.returncode is None:
            try:
                self._sock.close()
            except OSError:
                pass
            self.returncode = -9

    def poll(self):
        return self.returncode


def _find_ldbd_sibling() -> str | None:
    # <repo>/tools/ldb/ldb → dirname → <repo>/tools/ldb
    #                      → dirname → <repo>/tools
    #                      → dirname → <repo>
    # The in-tree build always emits ldbd to <repo>/build/bin/ldbd.
    # Anchoring on __file__ (not CWD) lets the CLI be invoked from
    # anywhere a user happens to be, without forcing --ldbd on every
    # call.
    try:
        script = os.path.realpath(__file__)
    except NameError:
        return None
    repo_root = os.path.dirname(os.path.dirname(os.path.dirname(script)))
    cand = os.path.join(repo_root, "build", "bin", "ldbd")
    if os.path.isfile(cand) and os.access(cand, os.X_OK):
        return cand
    return None


def find_ldbd(explicit: str | None) -> str:
    if explicit:
        if not os.access(explicit, os.X_OK):
            sys.stderr.write(f"ldb: --ldbd {explicit!r} not executable\n")
            sys.exit(2)
        return explicit
    onpath = shutil.which("ldbd")
    if onpath:
        return onpath
    sibling = _find_ldbd_sibling()
    if sibling:
        return sibling
    # In-tree dev fallback: ./build/bin/ldbd from CWD. Kept for the
    # case where the user vendors the CLI into a layout that doesn't
    # match the sibling heuristic but does have a `./build/bin/ldbd`
    # under their CWD.
    fallback = os.path.join(os.getcwd(), "build", "bin", "ldbd")
    if os.access(fallback, os.X_OK):
        return fallback
    sys.stderr.write(
        "ldb: ldbd not found on PATH, alongside the ldb script, "
        "or at ./build/bin/ldbd\n"
        "     pass --ldbd /path/to/ldbd to override\n")
    sys.exit(2)


def _split_ssh_target(target: str) -> tuple[str, str | None]:
    """Parse `[user@]host[:port]` into (user@host, port-or-None).

    ssh accepts `-p PORT` as a separate arg; we strip a trailing `:NNN`
    here so the user can write the natural `user@host:2222` form.
    """
    if ":" in target:
        host, _, port = target.rpartition(":")
        if port.isdigit():
            return host, port
    return target, None


def _build_ssh_argv(spec: DaemonSpec, fmt: str) -> list[str]:
    """Compose the full `ssh ...` command line for spawning ldbd remote."""
    assert spec.ssh_target is not None
    host, port = _split_ssh_target(spec.ssh_target)
    argv = ["ssh"]
    if port:
        argv += ["-p", port]
    if spec.ssh_key:
        # IdentitiesOnly avoids ssh-agent surprises picking the wrong key.
        argv += ["-i", spec.ssh_key, "-o", "IdentitiesOnly=yes"]
    if spec.ssh_options:
        # User passed a raw chunk; shlex-split so they can use `-o A=B -o C=D`.
        import shlex
        argv += shlex.split(spec.ssh_options)
    argv += [host, "--", spec.remote_ldbd,
             "--stdio", "--format", fmt, "--log-level", "error"]
    return argv


def spawn_daemon(spec_or_path, fmt: str, verbose: bool):
    """Spawn a daemon by spec (local, ssh, or unix-socket connection).

    Accepts either a DaemonSpec or, for backward-compat with older
    call-sites that already had a resolved ldbd path string, the bare
    path string (which it wraps into a local spec).

    For the socket case nothing is spawned — we connect to an existing
    `ldbd --listen unix:PATH` and return a Popen-shaped adapter so the
    rest of the code keeps working unchanged.
    """
    if isinstance(spec_or_path, DaemonSpec):
        spec = spec_or_path
    else:
        spec = DaemonSpec()
        spec.local_ldbd = spec_or_path

    if spec.is_socket:
        if verbose:
            sys.stderr.write(
                f"ldb: connecting to unix:{spec.socket_path}\n")
        return _SocketProc(spec.socket_path, autospawn=True, verbose=verbose)

    if spec.is_ssh:
        cmd = _build_ssh_argv(spec, fmt)
    else:
        cmd = [spec.local_ldbd, "--stdio", "--format", fmt,
               "--log-level", "error"]
    if verbose:
        sys.stderr.write(f"ldb: spawning {' '.join(cmd)}\n")
    return subprocess.Popen(
        cmd,
        stdin=subprocess.PIPE,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


# ----------------------------------------------------------------------
# Schema-driven param parsing.
# ----------------------------------------------------------------------

def coerce_value(raw: str, schema: dict) -> Any:
    """Best-effort coerce a key=value string per the schema's `type`.

    Falls back to the raw string when the schema is missing or unknown.
    Schema's `enum` does not constrain client-side; the daemon validates.
    """
    t = schema.get("type") if isinstance(schema, dict) else None
    if t == "integer":
        # accept hex (0x...) or decimal
        s = raw.strip()
        try:
            if s.lower().startswith("0x"):
                return int(s, 16)
            return int(s)
        except ValueError:
            raise ValueError(f"expected integer, got {raw!r}")
    if t == "number":
        try:
            return float(raw)
        except ValueError:
            raise ValueError(f"expected number, got {raw!r}")
    if t == "boolean":
        s = raw.strip().lower()
        if s in ("true", "1", "yes", "on"):
            return True
        if s in ("false", "0", "no", "off"):
            return False
        raise ValueError(f"expected boolean, got {raw!r}")
    if t == "array":
        # Comma-split. Coerce each item per items.type if present.
        items_schema = schema.get("items") if isinstance(schema, dict) else None
        items_schema = items_schema if isinstance(items_schema, dict) else {}
        parts = raw.split(",") if raw else []
        return [coerce_value(p, items_schema) for p in parts]
    if t == "object":
        # We don't try to parse nested objects from the CLI; accept JSON.
        try:
            return json.loads(raw)
        except json.JSONDecodeError as e:
            raise ValueError(f"expected JSON object, got {raw!r}: {e}")
    if t == "null":
        if raw.strip().lower() in ("null", "none", ""):
            return None
        raise ValueError(f"expected null, got {raw!r}")
    # type=string or unknown: accept verbatim. Also tolerate a JSON-like
    # input: if the value parses as a JSON literal AND looks
    # JSON-ish (starts with {/[/"), use that. Otherwise raw string.
    s = raw.lstrip()
    if s and s[0] in '{["':
        try:
            return json.loads(raw)
        except json.JSONDecodeError:
            pass
    return raw


def parse_kv_pairs(items: list[str]) -> list[tuple[str, str]]:
    """Split each `key=value` item; barf on bare flags."""
    pairs = []
    for it in items:
        if "=" not in it:
            raise ValueError(
                f"params must be key=value; got {it!r}. "
                f"Use `ldb <method> --help` to list expected params.")
        k, _, v = it.partition("=")
        if not k:
            raise ValueError(f"empty param name in {it!r}")
        pairs.append((k, v))
    return pairs


def build_params(pairs: list[tuple[str, str]],
                 view_pairs: list[tuple[str, str]],
                 schema: dict) -> dict:
    """Assemble a JSON-RPC params object from key=value pairs.

    - `pairs` go directly into the params dict, with type coercion from
      `schema.properties[k]` when available.
    - `view_pairs` collapse into params["view"] = {...} with the same
      coercion logic, special-casing `fields` as a comma-list, and
      `limit`/`offset` as integers.
    """
    props = schema.get("properties", {}) if isinstance(schema, dict) else {}
    params: dict[str, Any] = {}

    # Multiple `--key value --key value` for arrays: collect duplicates.
    seen: dict[str, list[str]] = {}
    for k, v in pairs:
        seen.setdefault(k, []).append(v)

    for k, vs in seen.items():
        kschema = props.get(k, {}) if isinstance(props, dict) else {}
        if len(vs) > 1:
            # multi-value form: treat as array regardless of schema
            items_schema = kschema.get("items", {}) if isinstance(kschema, dict) else {}
            if not isinstance(items_schema, dict):
                items_schema = {}
            params[k] = [coerce_value(v, items_schema) for v in vs]
        else:
            params[k] = coerce_value(vs[0], kschema)

    if view_pairs:
        view: dict[str, Any] = {}
        for k, v in view_pairs:
            if k == "fields":
                view["fields"] = [s for s in v.split(",") if s]
            elif k in ("limit", "offset"):
                try:
                    view[k] = int(v)
                except ValueError:
                    raise ValueError(f"--view {k}: expected integer, got {v!r}")
            elif k == "summary":
                vl = v.strip().lower()
                if vl in ("true", "1", "yes", "on"):
                    view[k] = True
                elif vl in ("false", "0", "no", "off"):
                    view[k] = False
                else:
                    raise ValueError(
                        f"--view summary: expected boolean, got {v!r}")
            else:
                # Forward unknown view keys verbatim — the daemon may
                # know what to do with them.
                view[k] = v
        params["view"] = view

    return params


# ----------------------------------------------------------------------
# Help rendering.
# ----------------------------------------------------------------------

def render_method_help(entry: dict) -> str:
    method = entry.get("method", "?")
    summary = entry.get("summary", "")
    out = []
    out.append(f"ldb {method}\n")
    if summary:
        out.append(f"  {summary}\n")
    out.append("\n")

    out.append(f"  cost_hint:        {entry.get('cost_hint', '?')}\n")
    out.append(f"  requires_target:  {entry.get('requires_target', False)}\n")
    out.append(f"  requires_stopped: {entry.get('requires_stopped', False)}\n")

    ps = entry.get("params_schema", {}) or {}
    props = ps.get("properties", {}) or {}
    required = set(ps.get("required", []) or [])
    out.append("\nParameters:\n")
    if not props:
        out.append("  (none)\n")
    else:
        for name, sub in props.items():
            if not isinstance(sub, dict):
                sub = {}
            t = sub.get("type", "any")
            req_marker = "required" if name in required else "optional"
            desc = sub.get("description", "")
            out.append(f"  {name}={t!s:<10}  {req_marker}")
            if desc:
                out.append(f"  {desc}")
            out.append("\n")

    out.append("\nView descriptors (optional, for array-returning calls):\n")
    out.append("  --view fields=k1,k2   project each item to these keys\n")
    out.append("  --view limit=N        cap items returned\n")
    out.append("  --view offset=N       skip first N items\n")
    out.append("  --view summary=true   small sample + total\n")

    return "".join(out)


def render_top_help(catalog: list[dict]) -> str:
    out = []
    out.append(
        "ldb — thin CLI for ldbd (LDB daemon)\n"
        "\n"
        "Usage:\n"
        "  ldb [--ldbd PATH | --ssh [user@]host[:port] | --socket PATH]\n"
        "      [--format json|cbor] [--verbose] [--raw]\n"
        "      <subcommand> [key=value ...] [--view k=v ...]\n"
        "  ldb [--ldbd PATH | --ssh [user@]host[:port] | --socket PATH]\n"
        "      [--format json|cbor] [--verbose] --repl\n"
        "  ldb <subcommand> --help\n"
        "  ldb --help | --version\n"
        "\n"
        "Daemon lifecycle:\n"
        "  Each one-shot `ldb <subcommand>` invocation spawns a fresh\n"
        "  ldbd, sends one request, and exits. target_id and any other\n"
        "  daemon-side state created by that call die with the\n"
        "  subprocess — so a second invocation that references the same\n"
        "  target_id will get -32000 \"unknown target_id\".\n"
        "\n"
        "  Use `--repl` to keep one daemon alive across many commands\n"
        "  in the same session. The REPL also reads from piped stdin\n"
        "  (e.g. `ldb --repl < commands.txt`) and processes every line\n"
        "  before exiting.\n"
        "\n"
        "  Alternatively, run `ldbd --listen unix:PATH` once out-of-band\n"
        "  and connect every `ldb` invocation with `--socket PATH`.\n"
        "  target_id and other daemon-side state survive across CLI\n"
        "  invocations because the daemon outlives them (§2 of\n"
        "  docs/35-field-report-followups.md). Phase-2 the daemon\n"
        "  serves multiple clients concurrently.\n"
        "\n"
        "  Auto-spawn: if --socket PATH points at a socket whose\n"
        "  backing daemon isn't running (ECONNREFUSED / ENOENT), the\n"
        "  CLI fork+execs `ldbd --listen unix:PATH` detached from the\n"
        "  client, waits up to ~3s for the daemon to bind, and\n"
        "  retries the connect. The spawned daemon survives the\n"
        "  client process; subsequent `ldb --socket PATH` calls reuse\n"
        "  it. The ldbd binary is found via $LDB_LDBD_SPAWN (if set),\n"
        "  then $PATH, then the sibling-of-`ldb` heuristic.\n"
        "\n"
        "Top-level options:\n"
        "  --ldbd PATH          local ldbd binary (default: PATH, then ./build/bin/ldbd)\n"
        "  --ssh TARGET         spawn ldbd on TARGET ([user@]host[:port]) via ssh\n"
        "                       (mutually exclusive with --ldbd and --socket)\n"
        "                       env LDB_SSH_TARGET overrides this flag\n"
        "  --ssh-key PATH       ssh identity file (forwarded as `ssh -i`)\n"
        "  --ssh-options STR    extra raw ssh options, e.g. \"-o ProxyJump=bastion\"\n"
        "  --ldbd-path PATH     where ldbd lives on the remote (default: ldbd on $PATH)\n"
        "  --socket PATH        connect to an already-running\n"
        "                       `ldbd --listen unix:PATH`. Mutually\n"
        "                       exclusive with --ssh / --ldbd. env\n"
        "                       LDB_SOCKET overrides this flag. Access\n"
        "                       control is filesystem-only (socket mode\n"
        "                       0600); no token auth in phase 1.\n"
        "  --format json|cbor   wire format on the daemon channel (default: json)\n"
        "  --verbose            log JSON-RPC traffic to stderr\n"
        "  --raw                print the full JSON-RPC envelope, not just data\n"
        "  --repl               drop into an interactive REPL (persistent daemon)\n"
        "  --help               this help\n"
        "  --version            print client version and exit\n"
        "\n"
        "Subcommands (from describe.endpoints):\n"
    )
    # Group by section prefix for readability (e.g. target.*, mem.*).
    rows = []
    for e in catalog:
        m = e.get("method", "?")
        s = e.get("summary", "")
        # Trim long summaries for the top-level listing.
        if len(s) > 70:
            s = s[:67] + "..."
        rows.append((m, s))
    rows.sort(key=lambda r: r[0])
    width = max((len(m) for m, _ in rows), default=20)
    for m, s in rows:
        out.append(f"  {m:<{width}}  {s}\n")
    out.append("\nRun `ldb <subcommand> --help` for per-method parameters.\n")
    return "".join(out)


# ----------------------------------------------------------------------
# Catalog fetch (one daemon roundtrip).
# ----------------------------------------------------------------------

def fetch_catalog(spec, fmt: str, verbose: bool) -> list[dict]:
    """Spawn ldbd, ask describe.endpoints, return the catalog list.

    Errors here are fatal (CLI can't function without the catalog).
    Accepts either a DaemonSpec or a bare ldbd path string.
    """
    proc = spawn_daemon(spec, fmt, verbose)
    try:
        if fmt == "cbor":
            tr = CborTransport(proc)
        else:
            tr = JsonTransport(proc)
        req = {"jsonrpc": "2.0", "id": "describe",
               "method": "describe.endpoints"}
        if verbose:
            sys.stderr.write(f"ldb: -> {json.dumps(req)}\n")
        tr.send(req)
        try:
            resp = tr.recv()
        except socket.timeout:
            sys.stderr.write(
                "ldb: daemon socket timeout after 300s while fetching "
                "catalog (daemon hung?)\n")
            sys.exit(1)
        if resp is None:
            stderr = proc.stderr.read().decode("utf-8", errors="replace")
            sys.stderr.write(
                f"ldb: daemon closed stdout while fetching catalog\n"
                f"     daemon stderr: {stderr}\n")
            sys.exit(1)
        if verbose:
            sys.stderr.write(f"ldb: <- {json.dumps(resp)[:200]}...\n")
        if not resp.get("ok"):
            err = resp.get("error", {})
            sys.stderr.write(
                f"ldb: describe.endpoints failed: "
                f"{err.get('code')} {err.get('message')}\n")
            sys.exit(1)
        eps = resp.get("data", {}).get("endpoints", [])
        if not isinstance(eps, list):
            sys.stderr.write("ldb: describe.endpoints: malformed catalog\n")
            sys.exit(1)
        return eps
    finally:
        # For _SocketProc both stdin and stdout each hold a dup of the
        # underlying socket fd via makefile(); both must be closed for
        # the daemon to see EOF and move on to the next caller.
        # Closing stdout on a real subprocess.Popen is also safe.
        try:
            proc.stdin.close()
        except Exception:
            pass
        try:
            proc.stdout.close()
        except Exception:
            pass
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            proc.kill()


# ----------------------------------------------------------------------
# RPC call.
# ----------------------------------------------------------------------

def do_rpc(spec, fmt: str, verbose: bool, method: str,
           params: dict) -> dict:
    proc = spawn_daemon(spec, fmt, verbose)
    try:
        tr = CborTransport(proc) if fmt == "cbor" else JsonTransport(proc)
        req = {"jsonrpc": "2.0", "id": "1", "method": method,
               "params": params}
        if verbose:
            sys.stderr.write(f"ldb: -> {json.dumps(req)}\n")
        tr.send(req)
        try:
            resp = tr.recv()
        except socket.timeout:
            sys.stderr.write(
                f"ldb: daemon socket timeout after 300s waiting for "
                f"{method!r} (daemon hung?)\n")
            sys.exit(1)
        if resp is None:
            stderr = proc.stderr.read().decode("utf-8", errors="replace")
            sys.stderr.write(
                f"ldb: daemon closed stdout (stderr was: {stderr})\n")
            sys.exit(1)
        if verbose:
            sys.stderr.write(f"ldb: <- {json.dumps(resp)[:512]}\n")
        return resp
    finally:
        # See fetch_catalog's matching block. _SocketProc's stdout
        # holds an independent makefile() handle on the socket fd;
        # close both halves so the daemon sees EOF promptly.
        try:
            proc.stdin.close()
        except Exception:
            pass
        try:
            proc.stdout.close()
        except Exception:
            pass
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            proc.kill()


# ----------------------------------------------------------------------
# Argument parsing.
# ----------------------------------------------------------------------

# We can't use argparse subparsers cleanly because subcommands are
# discovered at runtime from describe.endpoints. Hand-roll a simple
# two-pass parser:
#   1. Strip top-level options (anything starting with `--` recognized).
#   2. Whatever's left: first token = method; the rest = params + --view.

TOP_OPTIONS_WITH_ARG = {"--ldbd", "--format", "--ssh", "--ssh-key",
                        "--ssh-options", "--ldbd-path", "--socket"}
TOP_OPTIONS_NOARG    = {"--verbose", "--raw", "--repl"}
HELP_FLAGS           = {"--help", "-h"}

CLIENT_VERSION = "0.1.0"


def parse_argv(argv: list[str]) -> dict:
    """Hand-rolled parser. Returns a dict with parsed fields."""
    out = {
        "ldbd": None,
        "format": "json",
        "verbose": False,
        "raw": False,
        "repl": False,
        "help_top": False,
        "version": False,
        "method": None,
        "method_help": False,
        "params": [],     # list[str] — key=value
        "view": [],       # list[(key, value)]
        "ssh": None,
        "ssh_key": None,
        "ssh_options": None,
        "ldbd_path": None,
        "socket": None,
    }

    def _set_long_arg(key: str, val: str):
        if key == "--format":
            if val not in ("json", "cbor"):
                raise ValueError(
                    f"--format must be json|cbor, got {val!r}")
            out["format"] = val
        elif key == "--ldbd":
            out["ldbd"] = val
        elif key == "--ssh":
            out["ssh"] = val
        elif key == "--ssh-key":
            out["ssh_key"] = val
        elif key == "--ssh-options":
            out["ssh_options"] = val
        elif key == "--ldbd-path":
            out["ldbd_path"] = val
        elif key == "--socket":
            out["socket"] = val
        else:
            raise ValueError(f"unknown option: {key}")

    i = 0
    n = len(argv)
    while i < n:
        a = argv[i]
        if a in TOP_OPTIONS_WITH_ARG:
            if i + 1 >= n:
                raise ValueError(f"{a} requires an argument")
            _set_long_arg(a, argv[i + 1])
            i += 2
        elif a == "--verbose":
            out["verbose"] = True
            i += 1
        elif a == "--raw":
            out["raw"] = True
            i += 1
        elif a == "--repl":
            out["repl"] = True
            i += 1
        elif a in HELP_FLAGS and out["method"] is None:
            out["help_top"] = True
            i += 1
        elif a == "--version" and out["method"] is None:
            out["version"] = True
            i += 1
        elif "=" in a and a.startswith("--") and a.split("=", 1)[0] in TOP_OPTIONS_WITH_ARG:
            # Accept --foo=bar form too.
            key, _, val = a.partition("=")
            _set_long_arg(key, val)
            i += 1
        elif out["method"] is None:
            if a.startswith("--"):
                raise ValueError(f"unknown option: {a}")
            out["method"] = a
            i += 1
        elif a in HELP_FLAGS:
            out["method_help"] = True
            i += 1
        elif a == "--view":
            if i + 1 >= n:
                raise ValueError("--view requires k=v")
            kv = argv[i + 1]
            if "=" not in kv:
                raise ValueError(
                    f"--view expects k=v form, got {kv!r}")
            k, _, v = kv.partition("=")
            out["view"].append((k, v))
            i += 2
        elif a.startswith("--view="):
            kv = a[len("--view="):]
            if "=" not in kv:
                raise ValueError(f"--view= expects k=v, got {kv!r}")
            k, _, v = kv.partition("=")
            out["view"].append((k, v))
            i += 1
        else:
            # method param: must be key=value (unless it's --foo we
            # don't recognize, in which case complain).
            if a.startswith("--"):
                raise ValueError(
                    f"unknown option after method: {a}")
            out["params"].append(a)
            i += 1

    return out


# ----------------------------------------------------------------------
# Interactive REPL (post-V1 plan #10).
#
# Keeps ONE `ldbd --stdio` subprocess alive for the whole session. The
# win vs the one-shot CLI is daemon-side state persistence: `target_id`
# from `target.open` is usable in later `module.list` / `disasm.*` calls
# without re-opening the binary.
#
# Tab completion uses prompt_toolkit if importable, else readline.
# Meta-commands (prefix `:`) are routed locally; everything else is
# parsed by the same schema-driven path as the one-shot CLI.
# ----------------------------------------------------------------------

REPL_META_HELP = (
    "Meta-commands:\n"
    "  :help              show this help and list endpoints\n"
    "  :explain METHOD    print an endpoint's schema and summary\n"
    "  :cost              show per-endpoint p50 token-cost stats\n"
    "  :replay            re-run the most recent non-meta command\n"
    "  :quit, :q          exit (Ctrl-D / EOF also exits)\n"
    "\n"
    "Endpoint syntax (same as the CLI):\n"
    "  > target.open path=/bin/true\n"
    "  > module.list target_id=1 --view limit=5\n"
)


class _ReplSession:
    """Owns the persistent daemon and routes one line of input.

    Construction spawns the daemon and fetches the catalog once. Each
    `dispatch(line)` either runs a meta-command, runs an endpoint, or
    returns a sentinel meaning "exit".
    """

    EXIT = object()

    def __init__(self, spec, fmt: str, verbose: bool, raw: bool):
        self.spec = spec
        self.fmt = fmt
        self.verbose = verbose
        self.raw = raw
        self.proc = spawn_daemon(spec, fmt, verbose)
        self.tr = CborTransport(self.proc) if fmt == "cbor" else JsonTransport(self.proc)
        self.next_id = 0
        self.catalog = self._fetch_catalog()
        self.by_method = {e.get("method"): e for e in self.catalog
                          if isinstance(e, dict)}
        self.last_method: str | None = None
        self.last_params: dict | None = None

    # -- catalog / rpc --------------------------------------------------

    def _rpc(self, method: str, params: dict | None = None) -> dict:
        self.next_id += 1
        req = {"jsonrpc": "2.0", "id": f"r{self.next_id}", "method": method}
        if params is not None:
            req["params"] = params
        if self.verbose:
            sys.stderr.write(f"ldb: -> {json.dumps(req)}\n")
        self.tr.send(req)
        resp = self.tr.recv()
        if resp is None:
            stderr = self.proc.stderr.read().decode("utf-8", errors="replace")
            raise IOError(
                f"daemon closed stdout (stderr was: {stderr})")
        if self.verbose:
            sys.stderr.write(f"ldb: <- {json.dumps(resp)[:512]}\n")
        return resp

    def _fetch_catalog(self) -> list[dict]:
        resp = self._rpc("describe.endpoints")
        if not resp.get("ok"):
            err = resp.get("error", {})
            raise RuntimeError(
                f"describe.endpoints failed: {err.get('code')} "
                f"{err.get('message')}")
        eps = resp.get("data", {}).get("endpoints", [])
        if not isinstance(eps, list):
            raise RuntimeError("describe.endpoints: malformed catalog")
        return eps

    def close(self):
        try:
            self.proc.stdin.close()
        except Exception:
            pass
        try:
            self.proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            self.proc.kill()
            try:
                self.proc.wait(timeout=2)
            except subprocess.TimeoutExpired:
                pass

    # -- input parsing --------------------------------------------------

    @staticmethod
    def _tokenize(line: str) -> list[str]:
        """Shell-like splitting that respects single/double quotes.

        Falls back to a naive split on bare whitespace. We don't use
        shlex.split because we want to surface its errors as user-
        visible parse failures, not raise.
        """
        import shlex
        try:
            return shlex.split(line, posix=True)
        except ValueError as e:
            raise ValueError(f"parse error: {e}") from None

    def _parse_command(self, tokens: list[str]) -> tuple[str, list[str], list[tuple[str, str]]]:
        """Split tokens into (method, [k=v, ...], [(view_k, view_v), ...]).

        Same shape as the one-shot CLI's argparse pass, minus top-level
        options (already consumed at startup).
        """
        if not tokens:
            raise ValueError("empty command")
        method = tokens[0]
        params: list[str] = []
        view: list[tuple[str, str]] = []
        i = 1
        n = len(tokens)
        while i < n:
            a = tokens[i]
            if a == "--view":
                if i + 1 >= n:
                    raise ValueError("--view requires k=v")
                kv = tokens[i + 1]
                if "=" not in kv:
                    raise ValueError(f"--view expects k=v, got {kv!r}")
                k, _, v = kv.partition("=")
                view.append((k, v))
                i += 2
            elif a.startswith("--view="):
                kv = a[len("--view="):]
                if "=" not in kv:
                    raise ValueError(f"--view= expects k=v, got {kv!r}")
                k, _, v = kv.partition("=")
                view.append((k, v))
                i += 1
            elif a.startswith("--"):
                raise ValueError(f"unknown option in repl: {a}")
            else:
                params.append(a)
                i += 1
        return method, params, view

    # -- dispatch -------------------------------------------------------

    def dispatch(self, line: str):
        s = line.strip()
        if not s:
            return None
        if s.startswith(":"):
            return self._dispatch_meta(s)
        try:
            tokens = self._tokenize(s)
            method, params, view = self._parse_command(tokens)
        except ValueError as e:
            sys.stderr.write(f"ldb: {e}\n")
            return None
        return self._run_method(method, params, view, remember=True)

    def _dispatch_meta(self, s: str):
        if s in (":q", ":quit", ":exit"):
            return self.EXIT
        if s in (":help", ":h"):
            self._print_help()
            return None
        if s == ":cost":
            self._print_cost()
            return None
        if s == ":replay":
            if self.last_method is None:
                sys.stderr.write("ldb: nothing to replay yet\n")
                return None
            # Replay re-runs the SAME method+params; don't re-stamp
            # last_* so :replay :replay :replay all redo the same call.
            method = self.last_method
            params = self.last_params or {}
            resp = self._rpc(method, params)
            self._print_response(method, resp)
            return None
        if s.startswith(":explain"):
            parts = s.split(None, 1)
            if len(parts) != 2:
                sys.stderr.write("usage: :explain <method>\n")
                return None
            self._print_explain(parts[1].strip())
            return None
        sys.stderr.write(f"ldb: unknown meta-command: {s}\n")
        sys.stderr.write("     try :help\n")
        return None

    def _run_method(self, method, params, view, remember):
        entry = self.by_method.get(method)
        params_schema = (entry.get("params_schema", {}) or {}) if entry else {}
        required = list(params_schema.get("required", []) or [])
        try:
            kv_pairs = parse_kv_pairs(params)
            built = build_params(kv_pairs, view, params_schema)
        except ValueError as e:
            sys.stderr.write(f"ldb: {e}\n")
            return None
        missing = [r for r in required if r not in built]
        if missing:
            sys.stderr.write(
                f"ldb: {method}: required param(s) missing: "
                f"{', '.join(missing)}\n"
                f"     try `:explain {method}` for the parameter list.\n")
            return None
        try:
            resp = self._rpc(method, built)
        except IOError as e:
            sys.stderr.write(f"ldb: {e}\n")
            return self.EXIT
        if remember:
            self.last_method = method
            self.last_params = built
        self._print_response(method, resp)
        return None

    # -- printing -------------------------------------------------------

    def _print_response(self, method: str, resp: dict):
        # REPL always pretty-prints the FULL envelope (same as --raw on
        # the one-shot CLI). Agents/humans use the REPL to inspect
        # everything including _cost; the one-shot CLI's default of
        # data-only is for shell pipelines.
        sys.stdout.write(json.dumps(resp, indent=2) + "\n")
        sys.stdout.flush()
        if not resp.get("ok"):
            err = resp.get("error", {})
            sys.stderr.write(
                f"ldb: {method}: error {err.get('code')}: "
                f"{err.get('message', '')}\n")

    def _print_help(self):
        sys.stdout.write(REPL_META_HELP)
        sys.stdout.write("\nEndpoints (from describe.endpoints):\n")
        rows = []
        for e in self.catalog:
            m = e.get("method", "?")
            s = e.get("summary", "")
            if len(s) > 70:
                s = s[:67] + "..."
            rows.append((m, s))
        rows.sort(key=lambda r: r[0])
        width = max((len(m) for m, _ in rows), default=20)
        for m, s in rows:
            sys.stdout.write(f"  {m:<{width}}  {s}\n")
        sys.stdout.flush()

    def _print_explain(self, method: str):
        entry = self.by_method.get(method)
        if entry is None:
            sys.stderr.write(f"ldb: unknown method: {method}\n")
            return
        # Re-use render_method_help and ALSO dump the raw schema JSON so
        # `:explain` is the agent's canonical "how do I call this" view.
        sys.stdout.write(render_method_help(entry))
        sys.stdout.write("\nFull schema entry:\n")
        sys.stdout.write(json.dumps(entry, indent=2) + "\n")
        sys.stdout.flush()

    def _print_cost(self):
        try:
            resp = self._rpc(
                "describe.endpoints",
                {"view": {"include_cost_stats": True}})
        except IOError as e:
            sys.stderr.write(f"ldb: {e}\n")
            return
        if not resp.get("ok"):
            err = resp.get("error", {})
            sys.stderr.write(
                f"ldb: :cost: error {err.get('code')}: "
                f"{err.get('message', '')}\n")
            return
        eps = resp.get("data", {}).get("endpoints", []) or []
        rows = []
        for e in eps:
            if not isinstance(e, dict):
                continue
            n = e.get("cost_n_samples")
            if not isinstance(n, int) or n == 0:
                continue
            rows.append((
                e.get("method", "?"),
                n,
                e.get("cost_p50_tokens", "-"),
            ))
        if not rows:
            sys.stdout.write(
                "(no measured costs yet — issue some calls first)\n")
            sys.stdout.flush()
            return
        rows.sort(key=lambda r: r[0])
        width = max(len(m) for m, _, _ in rows)
        sys.stdout.write(
            f"  {'method':<{width}}  cost_n_samples  cost_p50_tokens\n")
        for m, n, p50 in rows:
            sys.stdout.write(f"  {m:<{width}}  {n:>14}  {p50!s:>15}\n")
        sys.stdout.flush()

    # -- completion -----------------------------------------------------

    def complete_first_token(self, prefix: str) -> list[str]:
        out = [m for m in self.by_method.keys()
               if m and m.startswith(prefix)]
        out += [c for c in (":help", ":explain", ":cost", ":replay",
                            ":quit", ":q")
                if c.startswith(prefix)]
        out.sort()
        return out

    def complete_param_key(self, method: str, prefix: str) -> list[str]:
        entry = self.by_method.get(method)
        if entry is None:
            return []
        props = (entry.get("params_schema", {}) or {}).get("properties", {}) or {}
        return sorted(f"{k}=" for k in props.keys()
                      if isinstance(k, str) and k.startswith(prefix))


def _make_completer_prompt_toolkit(session: _ReplSession):
    """Build a prompt_toolkit Completer; None if prompt_toolkit absent."""
    try:
        from prompt_toolkit.completion import Completer, Completion
    except ImportError:
        return None

    class LdbCompleter(Completer):
        def get_completions(self, document, complete_event):
            text_before = document.text_before_cursor
            words = text_before.split()
            # If text_before ends in whitespace, we're starting a new word.
            starting_new = (not text_before) or text_before[-1].isspace()
            if not words or (len(words) == 1 and not starting_new):
                # First token completion.
                prefix = words[0] if words else ""
                for c in session.complete_first_token(prefix):
                    yield Completion(c, start_position=-len(prefix))
                return
            method = words[0]
            current = "" if starting_new else words[-1]
            # Only complete on a fresh `--foo` or `key=...` slot; leave
            # the right-hand side of `key=` alone.
            if "=" in current:
                return
            for c in session.complete_param_key(method, current):
                yield Completion(c, start_position=-len(current))

    return LdbCompleter()


def _install_readline_completion(session: _ReplSession):
    """Install a readline completer. No-op if readline isn't importable."""
    try:
        import readline
    except ImportError:
        return

    # readline tokenization: we drop most word breaks so "target.open"
    # and "target_id=1" complete as single words.
    readline.set_completer_delims(" \t\n")

    state_cache: list[str] = []

    def completer(text, state):
        if state == 0:
            state_cache.clear()
            line = readline.get_line_buffer()
            begidx = readline.get_begidx()
            head = line[:begidx]
            words_before = head.split()
            if not words_before:
                state_cache.extend(session.complete_first_token(text))
            else:
                state_cache.extend(
                    session.complete_param_key(words_before[0], text))
        if state < len(state_cache):
            return state_cache[state]
        return None

    readline.set_completer(completer)
    readline.parse_and_bind("tab: complete")


def run_repl(spec, fmt: str, verbose: bool, raw: bool) -> int:
    """Drive an interactive ldb session against ONE persistent daemon.

    Returns the exit code. EOF, :quit, :q, :exit all exit cleanly with
    code 0. Daemon-spawn / catalog-fetch errors exit nonzero.
    """
    try:
        session = _ReplSession(spec, fmt, verbose, raw)
    except (IOError, RuntimeError) as e:
        sys.stderr.write(f"ldb: repl startup failed: {e}\n")
        return 1

    interactive = sys.stdin.isatty()

    # Choose input strategy. prompt_toolkit if available AND stdin is a
    # tty; readline as fallback (still has emacs-style line editing on
    # tty); plain stdin.readline() when piped (smoke tests).
    pt_session = None
    if interactive:
        try:
            from prompt_toolkit import PromptSession
            from prompt_toolkit.history import InMemoryHistory
            completer = _make_completer_prompt_toolkit(session)
            pt_session = PromptSession(
                completer=completer, history=InMemoryHistory())
        except ImportError:
            pt_session = None
            _install_readline_completion(session)

    try:
        while True:
            try:
                if pt_session is not None:
                    line = pt_session.prompt("ldb> ")
                elif interactive:
                    line = input("ldb> ")
                else:
                    line = sys.stdin.readline()
                    if line == "":
                        break  # EOF on piped stdin
                    line = line.rstrip("\n")
            except EOFError:
                break
            except KeyboardInterrupt:
                # Match shell-like UX: clear current line, keep looping.
                if interactive:
                    sys.stdout.write("\n")
                    continue
                break
            result = session.dispatch(line)
            if result is session.EXIT:
                break
    finally:
        session.close()
    if interactive:
        sys.stdout.write("\n")
    return 0


# ----------------------------------------------------------------------
# Entry point.
# ----------------------------------------------------------------------

def main(argv: list[str]) -> int:
    try:
        opts = parse_argv(argv[1:])
    except ValueError as e:
        sys.stderr.write(f"ldb: {e}\n")
        return 2

    if opts["version"]:
        print(f"ldb {CLIENT_VERSION}")
        return 0

    # Flag-over-env precedence for transport selectors. An explicit
    # --ssh / --socket on the command line wins over LDB_SSH_TARGET /
    # LDB_SOCKET; an unset / empty flag falls back to the env var.
    # This matches the CLI principle of least surprise — an operator
    # who typed --socket meant "this socket, right now"; if the env
    # silently overrode the flag they'd debug for a long time. The
    # daemon's resolve_store_root and resolve_observer_exec_allowlist
    # still use env-over-flag, because those are launcher-style knobs
    # whose env should pin policy across argv rewrites.
    env_ssh = os.environ.get("LDB_SSH_TARGET") or None
    if env_ssh and not opts["ssh"]:
        opts["ssh"] = env_ssh

    env_socket = os.environ.get("LDB_SOCKET") or None
    if env_socket and not opts["socket"]:
        opts["socket"] = env_socket

    # All three transport selectors are mutually exclusive. We surface
    # this client-side so the user gets a fast, locally-rendered error
    # instead of a confusing "tried to spawn ldbd while a socket was
    # already configured" later in the pipeline.
    if opts["socket"] and (opts["ssh"] or opts["ldbd"]):
        sys.stderr.write(
            "ldb: --socket is mutually exclusive with --ssh and --ldbd\n")
        return 2
    if opts["ssh"] and opts["ldbd"]:
        sys.stderr.write(
            "ldb: --ssh and --ldbd are mutually exclusive\n")
        return 2

    spec = DaemonSpec()
    if opts["socket"]:
        spec.socket_path = opts["socket"]
    elif opts["ssh"]:
        spec.ssh_target = opts["ssh"]
        spec.ssh_key = opts["ssh_key"]
        spec.ssh_options = opts["ssh_options"]
        if opts["ldbd_path"]:
            spec.remote_ldbd = opts["ldbd_path"]
    else:
        spec.local_ldbd = find_ldbd(opts["ldbd"])
    fmt = opts["format"]
    verbose = opts["verbose"]

    if opts["repl"]:
        # --repl ignores any positional method; the user drives the
        # session interactively. We still respect --raw/--verbose/--format.
        return run_repl(spec, fmt, verbose, opts["raw"])

    # Fetch catalog only when we need it.
    needs_catalog = (
        opts["help_top"] or opts["method_help"] or opts["method"] is not None
    )
    catalog: list[dict] = []
    if needs_catalog:
        catalog = fetch_catalog(spec, fmt, verbose)

    if opts["help_top"]:
        sys.stdout.write(render_top_help(catalog))
        return 0

    if opts["method"] is None:
        sys.stderr.write(
            "ldb: missing subcommand. Try `ldb --help`.\n")
        return 2

    method = opts["method"]
    entry = next((e for e in catalog if e.get("method") == method), None)

    if opts["method_help"]:
        if entry is None:
            sys.stderr.write(
                f"ldb: unknown method {method!r}. Try `ldb --help`.\n")
            return 2
        sys.stdout.write(render_method_help(entry))
        return 0

    if entry is None:
        # Allow the daemon to be authoritative — it'll emit -32601 with
        # a clear message. Useful if the catalog is somehow stale.
        # We still want exit 1 from that path.
        params_schema = {}
    else:
        params_schema = entry.get("params_schema", {}) or {}

    # Validate required params client-side for nicer error messages.
    required = list(params_schema.get("required", []) or [])
    try:
        kv_pairs = parse_kv_pairs(opts["params"])
        params = build_params(kv_pairs, opts["view"], params_schema)
    except ValueError as e:
        sys.stderr.write(f"ldb: {e}\n")
        return 2

    missing = [r for r in required if r not in params]
    if missing:
        sys.stderr.write(
            f"ldb: {method}: required param(s) missing: "
            f"{', '.join(missing)}\n"
            f"     run `ldb {method} --help` for the parameter list.\n")
        return 2

    resp = do_rpc(spec, fmt, verbose, method, params)

    if opts["raw"]:
        sys.stdout.write(json.dumps(resp, indent=2) + "\n")
    elif resp.get("ok") is True:
        sys.stdout.write(json.dumps(resp.get("data", {}), indent=2) + "\n")
    else:
        err = resp.get("error", {})
        sys.stderr.write(
            f"ldb: {method}: error {err.get('code')}: "
            f"{err.get('message', '')}\n")
        if "data" in err:
            sys.stderr.write(json.dumps(err["data"], indent=2) + "\n")
        return 1

    return 0 if resp.get("ok") else 1


if __name__ == "__main__":
    try:
        rc = main(sys.argv)
    except KeyboardInterrupt:
        rc = 130
    except IOError as e:
        # Surfaces both classic file-IO failures and the unix-socket
        # `connect()` path's IOError from `_SocketProc.__init__`.
        # Without this the agent sees an opaque Python traceback for
        # the common "daemon isn't running" case.
        sys.stderr.write(f"ldb: {e}\n")
        rc = 1
    sys.exit(rc)
